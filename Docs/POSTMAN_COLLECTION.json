              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PRODUCT_ID_HERE"
                }
              ]
            },
            "description": "Eliminar un producto (soft delete) - Solo Admin"
          }
        },
        {
          "name": "Get Product Stats",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
